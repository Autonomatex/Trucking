# Copy to .env for local overrides. On Replit, DATABASE_URL and SESSION_SECRET
# are already provided as environment secrets — you do not need to set them here.

ENVIRONMENT=development
PORT=8000
LOG_LEVEL=INFO

# Provided by Replit's built-in Postgres database.
DATABASE_URL=postgresql://user:password@localhost:5432/app

# Redis, run via the "Autonomatex Redis" native workflow.
REDIS_URL=redis://localhost:6379/0

# JWT signing secret. On Replit this maps to the SESSION_SECRET secret.
SESSION_SECRET=change-me-in-production
