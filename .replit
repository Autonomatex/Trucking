modules = ["nodejs-24", "python-base-3.13"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Autonomatex Redis"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Autonomatex API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Autonomatex Celery Worker"

[[workflows.workflow]]
name = "Autonomatex Redis"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "redis-server --port 6379 --daemonize no"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Autonomatex API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/autonomatex-api && /home/runner/workspace/.pythonlibs/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Autonomatex Celery Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/autonomatex-api && /home/runner/workspace/.pythonlibs/bin/python -m celery -A app.infrastructure.workers.celery_app.celery_app worker --loglevel=info --concurrency=2"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "postgresql", "rustc"]
